# ===== NoLSAF staging env example =====
# Use this as a checklist for Render staging API + Vercel staging/preview.
# Do not paste production DATABASE_URL or production payment/SMS credentials here.

# --- Render staging API ---
NODE_ENV=production
PORT=4000
HOST=0.0.0.0

# Aiven MySQL staging URL.
# Format from Aiven service overview:
# mysql://USER:PASSWORD@HOST:PORT/defaultdb?ssl-mode=REQUIRED
DATABASE_URL=mysql://avnadmin:<password>@<host>.aivencloud.com:<port>/defaultdb?ssl-mode=REQUIRED

JWT_SECRET=<generate-a-staging-only-secret>
ENCRYPTION_KEY=<generate-a-staging-only-32-byte-base64-key>

# Required only when staging runs more than one API instance.
# Also configure sticky sessions on the load balancer/proxy for Socket.IO.
REDIS_URL=<staging-redis-url>
SOCKET_IO_REDIS_ADAPTER=false
SOCKET_IO_REDIS_URL=

# Keep false for web/API instances. Set true only on the dedicated staging worker
# process that should run scheduled jobs.
RUN_BACKGROUND_WORKERS=false

# Leave blank unless staging web/API share a parent custom domain.
# Example only: COOKIE_DOMAIN=.staging.example.com
COOKIE_DOMAIN=

# Must include the exact Vercel staging/preview URL.
CORS_ORIGIN=https://<vercel-staging-domain>
WEB_ORIGIN=https://<vercel-staging-domain>
APP_ORIGIN=https://<vercel-staging-domain>

# Use staging/sandbox provider keys where possible.
MAPBOX_ACCESS_TOKEN=<mapbox-token>
NEXT_PUBLIC_MAPBOX_TOKEN=<mapbox-public-token>
CLOUDINARY_CLOUD_NAME=<staging-cloudinary-cloud-or-folder-policy>
CLOUDINARY_API_KEY=<staging-cloudinary-key>
CLOUDINARY_API_SECRET=<staging-cloudinary-secret>
AFRICASTALKING_USERNAME=<sandbox-or-staging-username>
AFRICASTALKING_API_KEY=<sandbox-or-staging-key>
AFRICASTALKING_SENDER_ID=

# CoralCommerce hosted card checkout sandbox.
# Keep credentials in Render/Vercel secrets only; do not commit real values.
CORAL_UCF_ENABLED=false
CORAL_UCF_API_URL=https://dev.coralcommerce.com/Payserver/Service/Execute
CORAL_UCF_USERNAME=<coral-sandbox-username>
CORAL_UCF_PASSWORD=<coral-sandbox-password>
CORAL_UCF_ALIAS=<coral-merchant-alias>
# Optional fallback only. Leave blank to use the invoice/property currency (TZS or USD).
CORAL_UCF_CURRENCY=
CORAL_UCF_SHARED_ENCRYPTION_KEY=<coral-sandbox-encryption-key>
CORAL_UCF_CALLBACK_URL=https://<render-staging-api-domain>/webhooks/coralcommerce/card/callback
CORAL_UCF_POSTBACK_SUCCESS_URL=https://<render-staging-api-domain>/webhooks/coralcommerce/card/postback
CORAL_UCF_POSTBACK_FAILURE_URL=https://<render-staging-api-domain>/webhooks/coralcommerce/card/postback
# Required by current Node/OpenSSL builds for CoralCommerce Blowfish callback decryption.
NODE_OPTIONS=--openssl-legacy-provider

# --- Vercel staging/preview web ---
API_ORIGIN=https://<render-staging-api-domain>
NEXT_PUBLIC_API_URL=https://<render-staging-api-domain>
NEXT_PUBLIC_SOCKET_URL=https://<render-staging-api-domain>
