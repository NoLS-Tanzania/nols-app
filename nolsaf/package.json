{
  "name": "nolsaf",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.6.1",
  "workspaces": [
    "apps/api",
    "apps/web",
    "packages/shared",
    "packages/prisma"
  ],
  "devDependencies": {
    "@prisma/adapter-mariadb": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@prisma/debug": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "8.54.0",
    "@typescript-eslint/parser": "8.54.0",
    "cliui": "^9.0.1",
    "concurrently": "^9.0.1",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "snyk": "^1.1300.0",
    "typescript": "~5.9.2",
    "yargs": "^18.0.0"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "npm --workspace=@nolsaf/web run predev && concurrently -n api,web -c green,cyan \"npm --workspace=@nolsaf/api run dev\" \"npm --workspace=@nolsaf/web run dev\"",
    "dev:flow": "powershell -NoProfile -ExecutionPolicy Bypass -File start-dev.ps1",
    "dev:npm": "npm --workspace=@nolsaf/web run predev && concurrently -n api,web -c green,cyan \"npm --workspace=@nolsaf/api run dev\" \"npm --workspace=@nolsaf/web run dev\"",
    "build": "npm run --workspaces --if-present build",
    "lint": "npm run --workspaces --if-present lint",
    "typecheck": "npm run --workspaces --if-present typecheck",
    "bootstrap:admin": "npm --workspace=@nolsaf/api run bootstrap:admin --",
    "bootstrap:admin:staging": "npm --workspace=@nolsaf/api run bootstrap:admin:staging",
    "bootstrap:admin:production": "npm --workspace=@nolsaf/api run bootstrap:admin:production",
    "prisma:generate": "npm run --workspace=@nolsaf/prisma generate",
    "prisma:push": "npx prisma db push --schema=prisma/schema.prisma",
    "prisma:migrate": "npx prisma migrate deploy --schema=prisma/schema.prisma",
    "prisma:migrate:status": "npx prisma migrate status --schema=prisma/schema.prisma",
    "prisma:studio": "npx prisma studio --schema=prisma/schema.prisma",
    "smoke-test": "node scripts/smoke-test.mjs",
    "smoke:driver-payouts": "npm --workspace=@nolsaf/api run smoke:driver-payouts",
    "smoke-test:staging": "API_URL=$npm_config_api_url node scripts/smoke-test.mjs",
    "uptime:check": "node scripts/uptime-check.mjs",
    "no4p-otp:cleanup": "node scripts/cleanup-no4p-otp.mjs"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "pdf-parse": "^2.4.5",
    "prisma": "^7.3.0"
  },
  "pnpm": {
    "overrides": {
      "axios": "^1.15.2",
      "africastalking": {
        "axios": "^1.15.2",
        "lodash": "^4.17.24"
      },
      "diff": "4.0.4",
      "fast-xml-parser": ">=5.7.0",
      "@aws-sdk/xml-builder": "3.972.17",
      "glob": "10.5.0",
      "hono": "^4.12.25",
      "@hono/node-server": "1.19.14",
      "dompurify": "3.4.0",
      "sanitize-html": "^2.17.4",
      "mailparser": "3.9.3",
      "js-yaml": "4.1.1",
      "minimatch": ">=10.2.1",
      "jspdf": "4.2.1",
      "jws": "3.2.3",
      "lodash": "^4.17.24",
      "nodemailer": "8.0.5",
      "qs": "^6.15.2",
      "postcss": "^8.5.12",
      "next": {
        "postcss": "^8.5.12"
      },
      "shell-quote": "^1.8.4",
      "xcode": {
        "uuid": "^11.1.1"
      },
      "svix": ">=1.92.0",
      "ws": "^8.21.0",
      "expo": "~56.0.0",
      "react-native": "0.85.3"
    }
  },
  "overrides": {
    "axios": "^1.15.2",
    "africastalking": {
      "axios": "^1.15.2",
      "lodash": "^4.17.24"
    },
    "diff": "4.0.4",
    "fast-xml-parser": ">=5.7.0",
    "@aws-sdk/xml-builder": "3.972.17",
    "glob": "10.5.0",
    "hono": "^4.12.25",
    "@hono/node-server": "1.19.14",
    "dompurify": "3.4.0",
    "sanitize-html": "^2.17.4",
    "magicast": "0.5.2",
    "mailparser": "3.9.3",
    "js-yaml": "4.1.1",
    "minimatch": ">=10.2.1",
    "jspdf": "4.2.1",
    "jws": "3.2.3",
    "lodash": "^4.17.24",
    "nodemailer": "8.0.5",
    "qs": "^6.15.2",
    "postcss": "^8.5.12",
    "next": {
      "postcss": "^8.5.12"
    },
    "shell-quote": "^1.8.4",
    "xcode": {
      "uuid": "^11.1.1"
    },
    "svix": ">=1.92.0",
    "ws": "^8.21.0",
    "expo": "~56.0.0",
    "react-native": "0.85.3"
  }
}
