{
  "expo": {
    "name": "NoLSAF Partners",
    "slug": "nolsaf-partners",
    "scheme": "nolsafpartners",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "bundleIdentifier": "com.nolsaf.partners",
      "supportsTablet": true
    },
    "android": {
      "package": "com.nolsaf.partners"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-secure-store", "expo-font"]
  }
}
