{
  "framework": "nextjs",
  "installCommand": "cd ../.. && npm ci --include-workspace-root --workspace=@nolsaf/web --workspace=@nolsaf/shared --workspace=@nolsaf/prisma",
  "buildCommand": "cd ../.. && npm run build --workspace=@nolsaf/web",
  "outputDirectory": ".next",
  "ignoreCommand": "if [ \"$VERCEL_GIT_COMMIT_REF\" = \"staging\" ] || [ \"$VERCEL_GIT_COMMIT_REF\" = \"main\" ]; then exit 1; fi; exit 0"
}
