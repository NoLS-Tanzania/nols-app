# EAS archives from this Git root. Keep only source needed to install the npm
# workspace and build the NoLSAF mobile application.
.git/
.agents/
.codex*/
.claude/
.github/
.vscode/
.git-worktrees/
Android/
backups/
nolsapp2.1/

# Dependencies are installed by EAS.
node_modules/
**/node_modules/
nolsaf/.npm-cache/
nolsaf/.npm-cache-eas/

# Unrelated application workspaces: retain their manifests so npm can resolve
# the existing workspace lockfile without uploading their large source trees.
nolsaf/apps/api/**
!nolsaf/apps/api/package.json
nolsaf/apps/web/**
!nolsaf/apps/web/package.json
nolsaf/apps/public/**
!nolsaf/apps/public/package.json
nolsaf/apps/driver/**
!nolsaf/apps/driver/package.json

# Generated output and local deployment data.
**/.expo/
**/.next/
**/dist/
**/build/
**/coverage/
**/web-build/
nolsaf/backups/
nolsaf/archives/
nolsaf/artifacts/
nolsaf/docker-data/
nolsaf/.elasticbeanstalk/
nolsaf/.vercel/
*.log
**/*.log
*.tsbuildinfo
**/*.tsbuildinfo

# Native projects are generated by Expo prebuild.
nolsaf/apps/mobile/android/
nolsaf/apps/mobile/ios/

# Never upload local secrets.
.env
.env.*
**/.env
**/.env.*
**/secrets/
**/.secrets/
**/*.pem
**/*.key
**/*.cert
**/*.p12
**/*.sql
**/*.sql.gz
**/*.dump

# Local reports and OS/editor files.
**/.tmp/
**/.local-reports/
**/reports/
.DS_Store
Thumbs.db
